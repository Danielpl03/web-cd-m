{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/web-cd-m/browser",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/api/ssr" }],
  "functions": {
    "api/ssr.mjs": {
      "includeFiles": "dist/web-cd-m/**",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
